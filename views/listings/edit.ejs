<% layout("layouts/boilerplate") %>


<!-- Importing boilerplate html for all pages -->

<!-- this above imports boilerplate and boilerplate contains css -->





<h2>Edit the Listing</h2>

<div class="edit-container">
  <div class="edit-card">

    <h2 class="edit-title">Edit Listing</h2>

    <form 
      action="/listings/<%= listing._id %>?_method=PUT"
      method="POST"
      novalidate           
      class="needs-validation"
      enctype="multipart/form-data">
      <!-- To send the files through the form  -->

      <!--  nonvalidate means stop the default clent side vaidation 
        and use bootstrap client side validation using needs validation class of botstrap -->


      <!-- Title -->
      <div class="mb-3">
        <input
          type="text"
          name="listing[title]"
          value="<%= listing.title %>"
          class="custom-input form-control"
          required>

        <div class="invalid-feedback">
          Please provide a valid title.
        </div>
        <!-- this is used for client side validation  -->
      </div>

      <!-- Description -->
      <div class="mb-3">
        <textarea
          name="listing[description]"
          class="custom-input form-control"
          required><%= listing.description %></textarea>

        <div class="invalid-feedback">
          Please provide a valid description.
        </div>
                <!-- this is used for client side validation  -->

      </div>

      <!-- Price -->
      <div class="mb-3">
        <input
          type="number"
          name="listing[price]"
          value="<%= listing.price %>"
          class="custom-input form-control"
          min="1"
          required>

        <div class="invalid-feedback">
          Please provide a valid price.
        </div>
                <!-- this is used for client side validation  -->

      </div>

      <!-- City -->
      <div class="mb-3">
        <input
          type="text"
          name="listing[city]"
          value="<%= listing.city %>"
          class="custom-input form-control"
          required>

        <div class="invalid-feedback">
          Please provide a valid city.
        </div>
        <!-- this is used for client side validation  -->
      </div>

      <!-- Location -->
      <div class="mb-3">
        <input
          type="text"
          name="listing[location]"
          value="<%= listing.location %>"
          class="custom-input form-control">

        <div class="invalid-feedback">
          Please provide a valid location.
        </div>
                <!-- this is used for client side validation  -->

      </div>

      <!-- Country -->
      <div class="mb-3">
        <input
          type="text"
          name="listing[country]"
          value="<%= listing.country %>"
          class="custom-input form-control"
          required>

        <div class="invalid-feedback">
          Please provide a valid country.
        </div>
                <!-- this is used for client side validation  -->

      </div>

        <div class="mb-3">
          Original Listing Image <br>
          <img height="300"  width="450"  src="<%=originalUrl %>">
        </div>

        


      <!-- Image -->
      <div class="mb-3">
        <label for="image" class="form-label">New Image Link </label>
        <input
          type="file"
          name="listing[image]"
          class="custom-input form-control">

        <div class="invalid-feedback">
          Please provide a valid image URL.
        </div>
          <!-- this is used for client side validation  -->

      </div>
         

      

      <!-- Submit -->
      <button type="submit" class="update-btn">
        Update Listing
      </button>
    </form>
  </div>
</div>


