<% layout("layouts/boilerplate") %>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">

<div class="listing-detail">

  <header class="listing-detail-header">
    <div class="listing-detail-top">
      <% if (listing.category) { %>
        <a href="/listings/filter/<%= listing.category %>" class="category-chip"><%= listing.category %></a>
      <% } %>
      <a href="/listings" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back to explore</a>
    </div>
    <h1 class="listing-detail-title"><%= listing.title %></h1>
    <div class="listing-detail-meta">
      <span><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></span>
      <span><i class="fa-solid fa-user"></i> <%= listing.Owner ? listing.Owner.username : "Unknown" %></span>
    </div>
  </header>

  <div class="listing-hero-wrap">
    <img
      src="<%= listing.image.url %>"
      onerror="this.src='https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1200';"
      class="listing-hero-img"
      alt="<%= listing.title %>"
    >
  </div>

  <div class="listing-detail-grid">

    <div class="listing-detail-main">
      <div class="listing-info-card mb-4">
        <h3>About this place</h3>
        <p class="listing-description"><%= listing.description %></p>
      </div>

      <div class="listing-info-card">
        <h3>What this place offers</h3>
        <ul class="listing-details">
          <li><i class="fa-solid fa-map-pin"></i><div><strong>Location</strong><span><%= listing.location %></span></div></li>
          <li><i class="fa-solid fa-flag"></i><div><strong>Country</strong><span><%= listing.country %></span></div></li>
          <% if (listing.city) { %>
            <li><i class="fa-solid fa-city"></i><div><strong>City</strong><span><%= listing.city %></span></div></li>
          <% } %>
          <li><i class="fa-solid fa-user-check"></i><div><strong>Host</strong><span><%= listing.Owner ? listing.Owner.username : "Unknown" %></span></div></li>
        </ul>
      </div>

      <section class="listing-info-card listing-map-section mb-4">
        <h3><i class="fa-solid fa-map-location-dot"></i> Where you'll be</h3>
        <p class="map-address-text">
          <i class="fa-solid fa-location-dot"></i>
          <%= typeof mapAddress !== 'undefined' && mapAddress ? mapAddress : (listing.location + ', ' + listing.country) %>
        </p>
        <div
          id="listing-map"
          class="listing-map map-loading"
          role="img"
          aria-label="Map showing listing location"
          data-lat="<%= typeof mapLat !== 'undefined' && mapLat != null ? mapLat : '' %>"
          data-lng="<%= typeof mapLng !== 'undefined' && mapLng != null ? mapLng : '' %>"
          data-address="<%= typeof mapAddress !== 'undefined' ? mapAddress : '' %>"
          data-title="<%= listing.title %>"
        ></div>
        <a
          href="https://www.openstreetmap.org/search?query=<%= encodeURIComponent(typeof mapAddress !== 'undefined' && mapAddress ? mapAddress : listing.location) %>"
          class="map-external-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          <i class="fa-solid fa-arrow-up-right-from-square"></i> View on OpenStreetMap
        </a>
      </section>

      <% if (typeof currUser !== 'undefined' && currUser && listing.Owner && listing.Owner.equals(currUser._id)) { %>
        <div class="btn-group-actions">
          <a href="/listings/<%= listing._id %>/edit" class="btn-edit"><i class="fa-solid fa-pen"></i> Edit</a>
          <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline">
            <button type="submit" class="btn-delete"><i class="fa-solid fa-trash"></i> Delete</button>
          </form>
        </div>
      <% } %>

      <section class="review-section">
        <h4><i class="fa-solid fa-star"></i> Reviews</h4>

        <% if (typeof currUser !== 'undefined' && currUser) { %>
          <div class="review-form-card">
            <h5 class="review-form-title">Leave a review</h5>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
              <div class="mb-3">
                <label for="comment" class="form-label">Your experience</label>
                <textarea class="form-control" id="comment" name="review[comment]" rows="3" required placeholder="What did you love about this stay?"></textarea>
                <div class="invalid-feedback">Please provide a comment.</div>
              </div>
              <div class="mb-3">
                <label for="rating" class="form-label">Rating</label>
                <select class="form-select rating-select" id="rating" name="review[rating]">
                  <option value="5">★★★★★ Excellent</option>
                  <option value="4">★★★★☆ Great</option>
                  <option value="3">★★★☆☆ Good</option>
                  <option value="2">★★☆☆☆ Fair</option>
                  <option value="1">★☆☆☆☆ Poor</option>
                </select>
              </div>
              <button type="submit" class="btn btn-brand">Submit review</button>
            </form>
          </div>
        <% } else { %>
          <p class="review-login-prompt">
            <a href="/login" class="text-brand fw-semibold">Log in</a> to leave a review.
          </p>
        <% } %>

        <% if (listing.reviews && listing.reviews.length) { %>
          <ul class="review-list">
            <% for (let review of listing.reviews) { %>
              <li class="review-card">
                <div class="review-card-header">
                  <span class="review-avatar"><%= review.author.username.charAt(0).toUpperCase() %></span>
                  <div>
                    <div class="review-author"><%= review.author.username %></div>
                    <div class="review-rating">
                      <% for (let i = 1; i <= 5; i++) { %>
                        <span class="star <%= i <= review.rating ? 'filled' : 'empty' %>">★</span>
                      <% } %>
                    </div>
                  </div>
                </div>
                <div class="review-comment"><%= review.comment %></div>
                <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                  <button type="submit" class="delete-review-btn">Delete review</button>
                </form>
              </li>
            <% } %>
          </ul>
        <% } else { %>
          <p class="text-secondary mb-0">No reviews yet — be the first guest to share feedback.</p>
        <% } %>
      </section>
    </div>

    <aside class="listing-price-card listing-price-desktop">
      <div class="price">₹<%= Number(listing.price || 0).toLocaleString("en-IN") %></div>
      <p class="price-note">per night · free cancellation (demo)</p>
      <ul class="price-features">
        <li><i class="fa-solid fa-check"></i> Instant confirmation</li>
        <li><i class="fa-solid fa-check"></i> 24/7 guest support</li>
      </ul>
      <button type="button" class="btn btn-brand w-100">Reserve (demo)</button>
    </aside>

  </div>
</div>

<div class="mobile-book-bar d-lg-none">
  <div>
    <span class="mobile-book-price">₹<%= Number(listing.price || 0).toLocaleString("en-IN") %></span>
    <span class="mobile-book-note">per night</span>
  </div>
  <button type="button" class="btn btn-brand">Reserve</button>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script src="/js/map.js"></script>
